      "updated": 1768160276442,
      "link": null,
      "locked": false,
      "customData": {
        "aiGenerated": true,
        "mermaidCode": null,
        "bandCode": "config { direction: down, theme: strict }\n\ngroup WearableData { color: \"#e3f2fd\" } {\n  WearableDevices[icon] { icon: \"smartwatch\", label: \"Wearable Devices\", color: \"#3B82F6\" },\n  HealthConnect[icon] { icon: \"database\", label: \"Health Connect\", color: \"#10B981\" }\n}\nWearableDevices -> HealthConnect\n\ngroup Middleware { color: \"#f1f8e9\" } {\n  HCGateway[icon] { icon: \"api\", label: \"HC Gateway\", color: \"#8B5CF6\" }\n}\nHealthConnect -> HCGateway\n\ngroup DataProcessing { color: \"#fff8e1\" } {\n  DataCollection[icon] { icon: \"database\", label: \"Data Collection & Preprocessing\", color: \"#F59E0B\" },\n  EDA[icon] { icon: \"bar-chart\", label: \"Exploratory Data Analysis\", color: \"#3B82F6\" },\n  ClassImbalance[icon] { icon: \"balance\", label: \"Class Imbalance Handling\", color: \"#EF4444\" }\n}\nHCGateway -> DataCollection\nDataCollection -> EDA\nEDA -> ClassImbalance\n\ngroup MachineLearning { color: \"#f3e5f5\" } {\n  MLModels[icon] { icon: \"cpu\", label: \"Machine Learning Models\", color: \"#8B5CF6\" },\n  Ensemble[icon] { icon: \"merge\", label: \"Ensemble Model\", color: \"#F59E0B\" }\n}\nClassImbalance -> MLModels\nMLModels -> Ensemble\n\ngroup Output { color: \"#e8f5e9\" } {\n  Prediction[icon] { icon: \"activity\", label: \"Final Health Prediction\", color: \"#10B981\" }\n}\nEnsemble -> Prediction",
        "diagramType": "band",
        "diagramColor": "rainbow",
        "drawStyle": "strict",
        "groupId": "ox5i6515ho"
      }
    },
